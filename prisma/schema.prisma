generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 部门表
model Department {
  id                Int      @id @default(autoincrement())
  code              String   @unique
  name              String
  nameEn            String?  @map("name_en")
  type              String?
  description       String?
  leaderId          Int?     @unique @map("leader_id")
  siteLocation      String?  @map("site_location")
  internalChannel   String?  @map("internal_channel")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  leader            Personnel? @relation("DepartmentLeader", fields: [leaderId], references: [id])
  personnel         Personnel[] @relation("PersonnelDepartment")
  sourceArchives    Archive[] @relation("SourceDepartment")
  respArchives      Archive[] @relation("RespDepartment")

  @@map("departments")
}

// 人员表
model Personnel {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  name            String
  nameEn          String?  @map("name_en")
  title           String?
  codename        String?
  departmentId    Int?     @map("department_id")
  position        String?
  status          String   @default("现役")
  specialty       String?
  clearanceLevel  Int      @default(1) @map("clearance_level")
  esigCode        String?  @map("esig_code")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department      Department? @relation("PersonnelDepartment", fields: [departmentId], references: [id])
  ledDepartment   Department? @relation("DepartmentLeader")
  leadArchives    Archive[] @relation("ArchiveLeadPerson")
  signatures      ArchiveSignature[]
  historyChanges  ArchiveHistory[] @relation("HistoryChangedBy")
  teamMemberships TeamMember[]
  ledTeams        ExplorationTeam[] @relation("TeamLeader")

  @@index([status])
  @@index([clearanceLevel])
  @@index([departmentId])
  @@map("personnel")
}

// 档案主表
model Archive {
  id                      Int      @id @default(autoincrement())
  code                    String   @unique
  category                String
  title                   String
  status                  String   @default("活跃")
  threatLevel             String?  @map("threat_level")
  threatLevelColor        String?  @map("threat_level_color")
  archiveDate             DateTime? @map("archive_date")
  sourceDepartmentId      Int?     @map("source_department_id")
  responsibleDepartmentId Int?     @map("responsible_department_id")
  leadPersonId            Int?     @map("lead_person_id")
  lastUpdate              DateTime @updatedAt @map("last_update")
  accessLevel             String?  @map("access_level")
  description             String?
  mainDangers             String[] @map("main_dangers")
  details                 Json     @default("{}")
  finalReview             String?  @map("final_review")
  reviewStatus            String   @default("通过") @map("review_status")
  remarks                 String?
  imagePath               String?  @map("image_path")
  sourceText              String?  @map("source_text")
  attachmentText          String?  @map("attachment_text")
  customTemplate          String?  @map("custom_template")  @default("")
  useCustomTemplate       Boolean  @default(false) @map("use_custom_template")
  videoPath               String?  @map("video_path")
  createdAt               DateTime @default(now()) @map("created_at")

  sourceDepartment        Department? @relation("SourceDepartment", fields: [sourceDepartmentId], references: [id])
  responsibleDepartment   Department? @relation("RespDepartment", fields: [responsibleDepartmentId], references: [id])
  leadPerson              Personnel?  @relation("ArchiveLeadPerson", fields: [leadPersonId], references: [id])

  relationsFrom         ArchiveRelation[] @relation("RelationFrom")
  relationsTo           ArchiveRelation[] @relation("RelationTo")
  signatures            ArchiveSignature[]
  history               ArchiveHistory[]

  @@index([category])
  @@index([status])
  @@index([threatLevel])
  @@index([category, status])
  @@index([sourceDepartmentId])
  @@index([responsibleDepartmentId])
  @@index([leadPersonId])
  @@map("archives")
}

// 档案关联表
model ArchiveRelation {
  id                Int    @id @default(autoincrement())
  archiveId         Int    @map("archive_id")
  relatedArchiveId  Int    @map("related_archive_id")
  relationType      String @map("relation_type")
  createdAt         DateTime @default(now()) @map("created_at")

  archive           Archive @relation("RelationFrom", fields: [archiveId], references: [id], onDelete: Cascade)
  relatedArchive    Archive @relation("RelationTo", fields: [relatedArchiveId], references: [id], onDelete: Cascade)

  @@unique([archiveId, relatedArchiveId, relationType])
  @@map("archive_relations")
}

// 签名表
model ArchiveSignature {
  id          Int      @id @default(autoincrement())
  archiveId   Int      @map("archive_id")
  position    String
  name        String
  esigCode    String?  @map("esig_code")
  signedDate  DateTime? @map("signed_date")
  note        String?
  personnelId Int?     @map("personnel_id")
  createdAt   DateTime @default(now()) @map("created_at")

  archive     Archive @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  personnel   Personnel? @relation(fields: [personnelId], references: [id])

  @@unique([archiveId, position, name])
  @@map("archive_signatures")
}

// 变更历史表
model ArchiveHistory {
  id          Int      @id @default(autoincrement())
  archiveId   Int      @map("archive_id")
  changedById Int?     @map("changed_by_id")
  changeType  String   @map("change_type")
  fieldName   String?  @map("field_name")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  changedAt   DateTime @default(now()) @map("changed_at")

  archive     Archive  @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  changedBy   Personnel? @relation("HistoryChangedBy", fields: [changedById], references: [id])

  @@map("archive_history")
}

// 勘探队表
model ExplorationTeam {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  name            String
  nameEn          String?  @map("name_en")
  leaderId        Int?     @unique @map("leader_id")
  status          String   @default("待命")
  memberCount     Int      @default(0) @map("member_count")
  currentLocation String?  @map("current_location")
  createdAt       DateTime @default(now()) @map("created_at")

  leader          Personnel? @relation("TeamLeader", fields: [leaderId], references: [id])
  members         TeamMember[]

  @@map("exploration_teams")
}

// 队员关联表
model TeamMember {
  teamId      Int      @map("team_id")
  personnelId Int      @map("personnel_id")
  role        String?
  joinedAt    DateTime @default(now()) @map("joined_at")

  team        ExplorationTeam @relation(fields: [teamId], references: [id])
  personnel   Personnel       @relation(fields: [personnelId], references: [id])

  @@id([teamId, personnelId])
  @@map("team_members")
}

// 新闻通报表
model NewsBulletin {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  title       String
  summary     String?
  content     String?
  category    String   @default("组织新闻")
  priority    String   @default("INFO")
  featured    Boolean  @default(false)
  imageUrl    String?  @map("image_url")
  publishedAt DateTime @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([priority])
  @@index([featured])
  @@index([publishedAt(sort: Desc)])
  @@map("news_bulletins")
}

// 装备物资表
model EquipmentItem {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  subtitle      String?
  description   String?
  category      String
  price         Int?
  currency      String?
  originalPrice String?  @map("original_price")
  stock         Int      @default(0)
  status        String   @default("available")
  badge         String?
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([status])
  @@map("equipment_items")
}

// 用户评价表
model Review {
  id         Int      @id @default(autoincrement())
  author     String
  content    String
  rating     Int
  date       DateTime
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([rating])
  @@index([verified])
  @@index([date(sort: Desc)])
  @@map("reviews")
}

// 系统公告表
model SystemAnnouncement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   @default("info")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([order])
  @@map("system_announcements")
}

// 模板库表
model ArchiveTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  content     String
  category    String?  @default("general")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("archive_templates")
}
